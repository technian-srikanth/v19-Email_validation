<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_list_web_domain" model="ir.ui.view">
        <field name="name">web.domain.list</field>
        <field name="model">web.domain</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="is_disposable"/>
                <field name="is_catchall"/>
            </list>
        </field>
    </record>

    <record id="view_form_web_domain" model="ir.ui.view">
        <field name="name">web.domain.form</field>
        <field name="model">web.domain</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="is_disposable"/>
                        <field name="is_catchall"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_web_domain" model="ir.actions.act_window">
        <field name="name">Web Domain</field>
        <field name="res_model">web.domain</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>